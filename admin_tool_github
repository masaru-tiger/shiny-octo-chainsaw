import streamlit as st
import pandas as pd
from sqlalchemy import create_engine, text

# --- データベース接続設定 (app.pyと同じロジック) ---
def init_connection():
    try:
        db_conf = st.secrets["database"]
        # パスワードを安全にエンコード（特殊文字対策）
        safe_password = urllib.parse.quote_plus(db_conf['password'])
        
        # ポート6543を指定し、接続先URLを構築
        db_url = (
            f"postgresql://{db_conf['user']}:{safe_password}@"
            f"{db_conf['host']}:6543/{db_conf['database']}"
        )
        
        # SSL接続を必須にして安定化
        return create_engine(
            db_url, 
            connect_args={'sslmode': 'require'}, 
            pool_pre_ping=True
        )
    except Exception as e:
        st.error(f"接続設定エラー: {e}")
        st.stop()

# エンジンの初期化
engine = init_connection()

def run_admin_tool():
    st.set_page_config(page_title="Smart Stock Admin", layout="wide")
    st.title("🛠 Smart Stock データベース管理者ツール")
    st.write("データベースの値を直接修正・上書きします。操作には注意してください。")

    # 1. データの読み込みと表示
    st.subheader("📊 現在の登録データ一覧")
    with engine.connect() as conn:
        df = pd.read_sql("SELECT * FROM items", conn)
    
    # 検索機能（簡易フィルタ）
    search_q = st.text_input("商品名や分類で検索", "")
    if search_q:
        df = df[df['name'].str.contains(search_q, na=False) | df['category'].str.contains(search_q, na=False)]
    
    st.dataframe(df, use_container_width=True)

    st.divider()

    # 2. 修正用UI
    st.subheader("✏️ データの修正")
    
    # 修正したいアイテムのIDを選択
    item_ids = df['id'].tolist() if not df.empty else []
    target_id = st.selectbox("修正するアイテムの ID を選択してください", item_ids)

    if target_id:
        # 選択された行の現在の値を取得
        target_row = df[df['id'] == target_id].iloc[0]
        
        st.info(f"現在選択中: 【{target_row['category']}】 {target_row['name']} (ID: {target_id})")

        # 修正入力フォーム
        with st.form("edit_form"):
            col1, col2 = st.columns(2)
            
            with col1:
                new_cat = st.text_input("分類", value=target_row['category'])
                new_name = st.text_input("商品名", value=target_row['name'])
                new_jan = st.text_input("JANコード", value=target_row['jan_code'])
                new_cap = st.text_input("単位", value=target_row['capacity'])
            
            with col2:
                new_qty = st.number_input("現在数", value=float(target_row['quantity']))
                new_rate = st.number_input("1日の消費量", value=float(target_row['daily_rate']))
                new_threshold = st.number_input("通知しきい値", value=float(target_row['threshold']))
                new_group = st.number_input("グループID", value=int(target_row['group_id']))

            submit = st.form_submit_button("🚀 データベースを更新（上書き）")

            if submit:
                try:
                    with engine.begin() as conn:
                        conn.execute(text("""
                            UPDATE items 
                            SET category = :cat,
                                name = :name,
                                jan_code = :jan,
                                capacity = :cap,
                                quantity = :qty,
                                daily_rate = :rate,
                                threshold = :threshold,
                                group_id = :gid
                            WHERE id = :id
                        """), {
                            "cat": new_cat, "name": new_name, "jan": new_jan, 
                            "cap": new_cap, "qty": new_qty, "rate": new_rate, 
                            "threshold": new_threshold, "gid": new_group, "id": target_id
                        })
                    st.success(f"ID {target_id} のデータを更新しました。ページを再読み込みしてください。")
                    # 再読み込み用のボタン
                    if st.button("表示を更新"):
                        st.rerun()
                except Exception as e:
                    st.error(f"更新エラーが発生しました: {e}")

    # 3. 削除機能（オプション）
    with st.expander("⚠️ 危険な操作: データの削除"):
        delete_id = st.number_input("削除するアイテムの ID", value=0)
        confirm = st.checkbox(f"ID {delete_id} を本当に削除しますか？")
        if st.button("❌ データを完全削除") and confirm:
            with engine.begin() as conn:
                conn.execute(text("DELETE FROM items WHERE id = :id"), {"id": delete_id})
            st.warning(f"ID {delete_id} を削除しました。")
            st.rerun()

if __name__ == "__main__":
    run_admin_tool()
